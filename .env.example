# 汇流社区 Docker 环境变量模板
# 复制此文件为 .env 文件并填入实际值

# ========== MySQL 配置 ==========
MYSQL_ROOT_PASSWORD=请设置MySQL root密码
MYSQL_DATABASE=test
MYSQL_USER=exchange
MYSQL_PASSWORD=请设置MySQL密码

# ========== Redis 配置 ==========
REDIS_PASSWORD=

# ========== JWT 配置 ==========
JWT_SECRET=请设置JWT密钥

# ========== AI API 配置（可选）============
AI_APIKEY=
AI_BASEURL=https://api.openai.com/v1
